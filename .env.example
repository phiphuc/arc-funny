# Provable - Environment Variables

# Deployer private key (DO NOT COMMIT)
PRIVATE_KEY=your_private_key_here

# Arc Testnet
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# Arcscan (for verification)
ARCSCAN_API_KEY=

# Etherscan (for Ethereum data)
ETHERSCAN_API_KEY=

# Alchemy/Infura (for RPC)
ALCHEMY_API_KEY=
INFURA_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Backend API
PORT=3001
NODE_ENV=development

# Deployed Contracts (fill after deploy)
PROVABLE_NFT_ADDRESS=
